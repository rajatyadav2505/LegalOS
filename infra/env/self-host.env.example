APP_ENV=production
APP_NAME=LegalOS
APP_URL=https://legalos.example.com
API_URL=https://legalos.example.com/api
DATABASE_URL=postgresql+psycopg://legalos:change-me@postgres:5432/legalos
DATABASE_ECHO=false
REDIS_URL=redis://valkey:6379/0
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=720
LOCAL_STORAGE_DIR=/var/lib/legalos/uploads
CORS_ORIGINS=https://legalos.example.com
OCR_LANGUAGES=eng
LOG_LEVEL=INFO
