# LegalOS Environment Configuration

# Database
DATABASE_URL=postgresql+asyncpg://legalos:legalos@localhost:5432/legalos
DATABASE_ECHO=false
AUTO_CREATE_DB=false
AUTO_SEED_DEMO=false

# Valkey
VALKEY_URL=redis://localhost:6379/0

# Storage
LOCAL_STORAGE_DIR=.data/storage
MAX_UPLOAD_SIZE_BYTES=26214400
HYBRID_EMBEDDING_DIMENSIONS=16
EMBEDDING_PROVIDER=deterministic-local
RERANKER_PROVIDER=deterministic-local
GENERATION_PROVIDER=deterministic-local
GENERATION_MODEL_NAME=template-v1

# JWT
JWT_SECRET=change-me-in-production-use-a-real-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# App
APP_NAME=LegalOS
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_HEADERS=Authorization,Content-Type,Accept

# Seed data
SEED_DATA_PATH=tests/fixtures/seed_data.json
OCR_LANGUAGES=eng
OCR_PDF_RENDER_DPI=360
OCR_TESSERACT_CONFIG=--psm 6
OCR_MIN_EXTRACTED_TEXT_CHARS=32
